# compile-pdf environment variables — copy to .env and fill in.
# All variables are optional in development; production sets them per §1.10.

# --- Producer routing ---
# Which producer this container hosts. Values: rewrite | marks | impose | trap | all.
# Per-producer Dockerfile variants override; "all" is the dev default.
COMPILE_PRODUCER=all

# --- Identity ---
# Reported on /healthz; falls back to socket.gethostname() if unset.
COMPILE_INSTANCE_ID=

# --- Auth (spec §1.10) ---
# Comma-separated subset of: none, bearer, api-key, internal, basic
# "none" disables all auth (dev only).
COMPILE_AUTH_MODE=none
COMPILE_BEARER_TOKEN=
COMPILE_API_KEY=
COMPILE_INTERNAL_TOKEN=
COMPILE_BASIC_AUTH_ENABLED=
COMPILE_BASIC_AUTH_USER=
COMPILE_BASIC_AUTH_PASS=

# --- Cache + queue (spec §1.5 + §1.6) ---
# Redis broker for Celery + cache index.
COMPILE_REDIS_URL=
# Cache backend kind reported on /healthz: memory | redis | bucket.
COMPILE_CACHE_BACKEND=memory

# --- Object storage (spec §1.6 + §1.7) ---
# S3-compatible bucket used as authoritative output store + lineage JSONL stream.
COMPILE_S3_ENDPOINT=
COMPILE_S3_BUCKET=compile-outputs
COMPILE_S3_ACCESS_KEY=
COMPILE_S3_SECRET_KEY=
COMPILE_S3_REGION=

# --- Codex client (spec §0 — multi-instance routing contract) ---
# Single base URL OR a multi-instance pool.
CODEX_API_BASE=
# Comma-separated plant=url pairs (e.g. "plant-a=http://codex-a:8080,plant-b=http://codex-b:8080").
CODEX_API_BASES=
# Routing mode: single | plant | failover | hybrid (default hybrid for N>1).
CODEX_ROUTE_MODE=
# Plant identifier (§1.10 plant scoping).
CODEX_PLANT=
# Affinity hash key (§0).
CODEX_AFFINITY_KEY=
# Section versions Compile was built against — must satisfy live Codex /v1/contract.
CODEX_REQUIRED_SECTION_VERSIONS={"color":"1.0.0","geom":"1.0.0"}
# Auth tokens forwarded to Codex calls.
CODEX_BEARER_TOKEN=
CODEX_INTERNAL_TOKEN=

# --- Version-skew policy (spec §1.11c) ---
# strict | permissive | refuse-all
COMPILE_VERSION_SKEW_POLICY=strict

# --- Verify-level default for rewrite (spec §2.3) ---
# strict | structural | paranoid
COMPILE_REWRITE_VERIFY_LEVEL=strict

# --- Trap engine (spec §1.11b + §5.5) ---
# pure_python (default) | ghostscript ([trap-gs] extra) | external ([trap-external] extra)
COMPILE_TRAP_ENGINE=pure_python

# --- Observability (spec §1.11) ---
# Prometheus exposition is always on at /metrics; OTel traces are opt-in.
COMPILE_OTEL_ENDPOINT=
# Optional bearer for /metrics scraping.
COMPILE_METRICS_TOKEN=
